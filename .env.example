# Senate Chef — environment variables
# Copy this file to ".env" and fill in your Supabase project values.
# Only EXPO_PUBLIC_* vars are exposed to the app bundle. The anon key is safe to
# ship — security is enforced by Row-Level Security + RPCs (see supabase/migrations).

# Project URL, e.g. https://abcdefgh.supabase.co
EXPO_PUBLIC_SUPABASE_URL=

# Public "anon" API key (Project Settings → API → Project API keys → anon public)
EXPO_PUBLIC_SUPABASE_ANON_KEY=
