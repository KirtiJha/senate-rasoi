{
  "expo": {
    "name": "Senate Rasoi",
    "slug": "senate-rasoi",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "senaterasoi",
    "userInterfaceStyle": "automatic",
    "backgroundColor": "#F7F7F5",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.senaterasoi.app"
    },
    "android": {
      "package": "com.senaterasoi.app",
      "adaptiveIcon": {
        "backgroundColor": "#FF5A3C",
        "foregroundImage": "./assets/images/android-icon-foreground.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FF5A3C",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 120
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Senate Rasoi needs photo access so you can add a picture of your dish."
        }
      ],
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
