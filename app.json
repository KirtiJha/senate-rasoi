{
  "expo": {
    "name": "Aangan",
    "slug": "aangan",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "aangan",
    "userInterfaceStyle": "automatic",
    "backgroundColor": "#F7F7F5",
    "updates": {
      "enabled": true,
      "fallbackToCacheTimeout": 0,
      "url": "https://u.expo.dev/aangan"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.aangan.app",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Aangan needs photo access so you can add a picture to your listing.",
        "NSCameraUsageDescription": "Aangan needs camera access to take photos for your listing.",
        "NSContactsUsageDescription": "Aangan needs contacts access to help you connect with neighbours."
      }
    },
    "android": {
      "package": "com.aangan.app",
      "adaptiveIcon": {
        "backgroundColor": "#FF5A3C",
        "foregroundImage": "./assets/images/android-icon-foreground.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "CAMERA",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FF5A3C",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 120
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Aangan needs photo access so you can add a picture of your listing."
        }
      ],
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
